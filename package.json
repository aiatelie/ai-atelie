{
  "name": "ai-atelie",
  "private": true,
  "version": "0.1.0",
  "license": "MIT",
  "type": "module",
  "workspaces": [
    "api",
    "web",
    "mcp"
  ],
  "scripts": {
    "dev": "concurrently --raw -k -n api,web -c blue,green \"bun run dev:api\" \"bun run dev:web\"",
    "dev:api": "cd api && bun run --watch src/index.ts",
    "dev:web": "cd web && bun run dev",
    "build": "cd web && bun run build",
    "preview": "cd web && bun run preview",
    "release": "bunx changelogen --release --push",
    "release:manual": "bunx bumpp -r --no-push --execute 'bunx changelogen --no-bump --output CHANGELOG.md'"
  },
  "devDependencies": {
    "@playwright/test": "^1.59.1",
    "bumpp": "^11.0.1",
    "changelogen": "0.6.2",
    "concurrently": "^9.0.1"
  }
}
