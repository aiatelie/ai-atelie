# AI Atelie API — environment configuration
#
# Copy to `.env` next to this file and edit per environment. The defaults
# below preserve the pre-extraction layout (everything under web/) so no
# data migration is needed for local dev. For cloud: flip PROJECTS_ROOT
# and SHARED_ROOT to point at your durable storage mount, keep the rest.

# Port the API binds. Vite (web/) proxies /api/* and /p/* here.
API_PORT=5174

# Where per-project sandbox content lives (manifest.json, files, .meta/, exports/, uploads/).
# Default: <repo>/web/projects (back-compat with the pre-Bun layout).
# PROJECTS_ROOT=/abs/path/to/projects

# Workspace-wide shared blobs (assets.json, etc) — written by /api/shared/:key.
# Default: <repo>/web/.data
# SHARED_ROOT=/abs/path/to/shared

# Where the legacy comment-edit fallback (no projectId) scopes the AI to.
# Default: <repo>/web (lets the AI edit the SPA itself; only used by older
# clients that don't pass a projectId).
# LEGACY_EDITOR_ROOT=/abs/path/to/web

# Skills directory (Claude Code + kimi --skills-dir).
# Default: <repo>/skills
# SKILLS_DIR=/abs/path/to/skills

# MCP server directory (ask-user, starters, capabilities, ask-user-http).
# Default: <repo>/mcp
# MCP_DIR=/abs/path/to/mcp

# Diagnostic screenshot dir parent (per-project subdirs created at runtime).
# Default: $TMPDIR/ai-atelie-comments
# SCREENSHOT_TMP_ROOT=/abs/path/to/scratch

# Per-run log files (one per /api/comment-edit POST). /api/_debug/runs
# surfaces the path so you can tail -f a stuck turn.
# Default: $TMPDIR/ai-atelie-runs
# RUN_LOGS_DIR=/abs/path/to/run-logs

# Where exportOgraf spawns headless Chromium with the project iframe.
# Default: <repo>/playwright-tools  (gitignored, may not exist on a fresh
# clone — set to a directory that has the playwright runtime if you need
# OGraf export, otherwise leave unset and that one capability will skip).
# PLAYWRIGHT_TOOLS_DIR=/abs/path/to/playwright-tools

# CORS origin allowlist for cross-origin SPA dev (defaults to "*" in dev).
# In prod, set to your editor's origin, e.g. https://your-domain.example
# CORS_ORIGIN=*

# Kimi prewarm pool — long-lived kimi worker per (rootDir, sessionId).
# Subsequent turns of the same thread skip the cold-start tax (~5s vs
# fresh spawn). Default ON. Set to "0" to disable and fall back to the
# fresh-spawn-per-turn path.
# KIMI_POOL_ENABLED=1

# Idle window before a pooled worker is evicted (default 30 min).
# KIMI_POOL_IDLE_MS=1800000
