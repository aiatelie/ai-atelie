{
  "name": "ai-atelie-api",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "AI Atelie API server (Bun + Hono). Runs on its own port; Vite proxies /api/* and /p/* to it.",
  "scripts": {
    "dev": "bun run --watch src/index.ts",
    "start": "bun run src/index.ts",
    "test": "bun test src",
    "typecheck": "bun --bun tsc --noEmit"
  },
  "dependencies": {
    "@anthropic-ai/claude-agent-sdk": "^0.2.132",
    "hono": "^4.12.18"
  },
  "devDependencies": {
    "@types/node": "^25.6.0",
    "typescript": "^6.0.3"
  }
}
