# Dependencies
node_modules/

# Build output
dist/
dist-ssr/
build/

# Logs
*.log
npm-debug.log*
yarn-debug.log*
pnpm-debug.log*
bun-debug.log*

# OS / editor
.DS_Store
.vscode/*
!.vscode/extensions.json
.idea/
*.swp
*.swo

# Env / secrets
.env
.env.*
!.env.example

# Claude Code: this repo's global ~/.gitignore ignores `.claude/`
# wholesale. Re-include the parts we want tracked (project-shared
# settings + dev-time contributor skills), then exclude per-user
# settings.local.json again.
!.claude/
!.claude/settings.json
!.claude/skills/
!.claude/skills/**
.claude/settings.local.json
.claude/worktrees/

# Playwright + PR-evidence artifacts. These are produced by the
# verify-with-playwright skill and uploaded to GitHub's user-attachments
# CDN — no need to track them locally beyond a few recent runs.
test-results/
playwright-report/
.evidence/

# Defense-in-depth: the setup-attach-session helper saves browser
# session state and cookies to ~/.local/state/aiatelie/ (well outside
# the repo) — but if anyone ever points it at a path inside the repo,
# these patterns make sure the cookies never get committed.
*-cookies.txt
chromium-profile/

# Per-user projects under web/projects/ are runtime data and not tracked,
# EXCEPT the bundled demo project. .meta/ (chat history) inside the demo
# is still per-user and stays ignored.
/web/projects/*
!/web/projects/demo/
/web/projects/demo/.meta/
/uploads/
# Elicit form attachments (runtime user uploads served to iframes)
web/public/uploads/

# Old / scratch / generated
_legacy/
scrap/
screenshots/
/export/

# Internal design / handoff notes (kept locally, not shipped)
NOTES-claude-design.txt
HANDOFF.txt
BACKEND-ARCH-CLAUDE-DESIGN.txt
MULTI-TENANT-CLAUDE-DESIGN.txt
_internal/

# Internal inspection scripts (not shipped)
playwright-tools/

# Personal user content — designs, templates, assets the maintainer
# created for their own use. The OSS repo ships only the framework.
# Local files in these paths stay on disk; they're just untracked.
# Anchored with a leading slash so they only match repo-root dirs and
# don't accidentally swallow same-named dirs deeper in the tree
# (e.g. web/src/components/editor/).
/bg/
/content/
/editor/
/pages/
/globe-lottie.json
/vite.config.js
/web/.data/
/web/src/assets/hero.png

# Local tooling caches
.cache/
.turbo/
.parcel-cache/
web/tests/e2e/.task-staging/
